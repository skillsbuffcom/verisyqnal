generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id        String   @id @default(cuid())
  type      String
  name      String
  profile   Json
  tags      String[]
  geography String?
  stage     String?
  createdAt DateTime @default(now())

  relationshipsAsA Relationship[] @relation("EntityA")
  relationshipsAsB Relationship[] @relation("EntityB")
}

model Relationship {
  id               String   @id @default(cuid())
  entityAId        String
  entityBId        String
  programmeId      String?
  type             String
  status           String
  formation        String
  confidence       Int?
  rationale        String?
  alignmentFactors String[]
  riskFlags        String[]
  governance       Json?
  memory           Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entityA Entity @relation("EntityA", fields: [entityAId], references: [id])
  entityB Entity @relation("EntityB", fields: [entityBId], references: [id])
}

model Programme {
  id        String   @id @default(cuid())
  name      String
  owner     String?
  geography String[]
  status    String?
  rules     Json?
  cohort    String?
  createdAt DateTime @default(now())
}
