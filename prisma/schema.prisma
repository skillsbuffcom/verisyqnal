generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Entity {
  id        String   @id @default(cuid())
  type      String
  name      String
  profile   Json
  tags      Json     @default("[]")
  geography String?
  stage     String?
  createdAt DateTime @default(now())

  relationshipsAsA Relationship[] @relation("EntityA")
  relationshipsAsB Relationship[] @relation("EntityB")

  @@index([type])
  @@index([name])
}

model Relationship {
  id               String   @id @default(cuid())
  entityAId        String
  entityBId        String
  programmeId      String?
  type             String
  status           String
  formation        String
  confidence       Int?
  rationale        String?
  alignmentFactors Json     @default("[]")
  riskFlags        Json     @default("[]")
  governance       Json?
  memory           Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  entityA Entity @relation("EntityA", fields: [entityAId], references: [id])
  entityB Entity @relation("EntityB", fields: [entityBId], references: [id])

  @@index([type])
  @@index([status])
  @@index([programmeId])
  @@index([entityAId])
  @@index([entityBId])
}

model Programme {
  id        String   @id @default(cuid())
  name      String
  owner     String?
  geography Json     @default("[]")
  status    String?
  rules     Json?
  cohort    String?
  createdAt DateTime @default(now())
}
